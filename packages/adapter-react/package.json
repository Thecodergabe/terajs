{
  "name": "@terajs/adapter-react",
  "version": "1.0.4",
  "description": "React interoperability adapter for mounting Terajs components in React applications.",
  "author": "Terajs Labs",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.d.ts.map"
  ],
  "keywords": [
    "terajs",
    "react",
    "adapter",
    "interop",
    "local-first"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@terajs/reactivity": "^1.0.4",
    "@terajs/renderer-web": "^1.0.4",
    "@terajs/runtime": "^1.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terajs/terajs.git"
  }
}
